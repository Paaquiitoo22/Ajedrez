@startuml clases_ajedrez
!theme plain

class Tablero {
  - casillas[8][8]: Pieza
  - turnoActual: Color
  - piezasBlancas: List<Pieza>
  - piezasNegras: List<Pieza>
  - puntuacionBlancas: int
  - puntuacionNegras: int
  + moverPieza(origen: Posicion, destino: Posicion): boolean
  + esMovimientoLegal(mov: Movimiento): boolean
  + hayJaque(color: Color): boolean
  + esJaqueMate(color: Color): boolean
  + capturarAlPaso(origen: Posicion, destino: Posicion): boolean
  + actualizarPuntuacion(color: Color, valor: int): void
  + promocionarPeon(peon: Peon, nuevaPieza: String): Pieza
}

abstract class Pieza {
  - color: Color
  - posicion: Posicion
  - valor: int
  + getMovimientosLegales(): List<Movimiento>
  + esMovimientoLegal(destino: Posicion): boolean
  + moverA(pos: Posicion): void
  + getValor(): int
}

class Peon {
  - primerMovimiento: boolean
  + esCapturaAlPaso(destino: Posicion): boolean
  + ejecutarCapturaAlPaso(tablero: Tablero): void
  + necesitaPromocion(posicion: Posicion): boolean
}

class Torre {
  + getValor(): int = 5
}

class Caballo {
  + getValor(): int = 3
}

class Alfil {
  + getValor(): int = 3
}

class Dama {
  + getValor(): int = 9
}

class Rey {
  - haMovido: boolean
  - enroqueCortoPosible: boolean
  - enroqueLargoPosible: boolean
  + getValor(): int = 0
}

class Posicion {
  - fila: int
  - columna: int
  + equals(other: Posicion): boolean
  + esUltimaFila(color: Color): boolean
}

class Movimiento {
  - origen: Posicion
  - destino: Posicion
  + esCaptura(): boolean
  + esCapturaAlPaso(): boolean
  + requierePromocion(): boolean
}

class Jugador {
  - color: Color
  - nombre: String
  - piezasCapturadas: List<Pieza>
  + getPuntuacion(): int
  + añadirPiezasCapturada(pieza: Pieza): void
}

enum Color {
  BLANCO
  NEGRO
}

class ValidadorMovimientos {
  + validarMovimiento(tablero: Tablero, mov: Movimiento): boolean
  + validarEnroque(tablero: Tablero): boolean
  + validarCapturaAlPaso(tablero: Tablero, mov: Movimiento): boolean
  + validarPromocion(peon: Peon, mov: Movimiento): boolean
  + calcularPuntuacion(piezas: List<Pieza>): int
}

class PromotorPiezas {
  + crearNuevaPieza(color: Color, tipo: String): Pieza
  + mostrarDialogoPromocion(color: Color): String
}

' Relaciones
Tablero ||--o{ Pieza : contiene
Tablero ||--o{ Jugador : tiene
Pieza ||--o| Posicion : ocupa
Pieza ..> Movimiento : genera
Pieza <|-- Peon
Pieza <|-- Torre
Pieza <|-- Caballo
Pieza <|-- Alfil
Pieza <|-- Dama
Pieza <|-- Rey
Movimiento ..> Posicion : usa
Tablero ..> ValidadorMovimientos : usa
Tablero ..> PromotorPiezas : usa
Jugador *--o{ Pieza : captura
Peon ..> PromotorPiezas : usa

@enduml