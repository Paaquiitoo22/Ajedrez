<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.tfg.ajedrez.controller.MenuController"
           stylesheets="@../css/estilo.css">

    <VBox alignment="CENTER" spacing="18" styleClass="login-container">
        <padding>
            <Insets top="25" right="25" bottom="25" left="25"/>
        </padding>

        <Label text="♞" styleClass="app-icon"/>
        <Label text="MiChess" styleClass="app-title"/>
        <Label text="Menú principal" styleClass="app-subtitle"/>

        <Label fx:id="lblUsuario" styleClass="footer-label"/>

        <Button fx:id="btnNuevaPartida" text="Nueva partida" onAction="#nuevaPartida" styleClass="primary-button"/>
        <Button text="Cargar partida" onAction="#cargarPartida" styleClass="secondary-button"/>
        <Button text="Historial" onAction="#historial" styleClass="secondary-button"/>
        <Button text="Cerrar sesión" onAction="#cerrarSesion" styleClass="ghost-button"/>
    </VBox>

</StackPane>