<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.tfg.ajedrez.controller.PartidaController"
            stylesheets="@../css/estilo.css"
            prefWidth="1100"
            prefHeight="720"
            styleClass="main-bg">

    <top>
        <HBox alignment="CENTER" spacing="20" styleClass="topbar">
            <Label fx:id="lblTurno" text="Turno: Blancas" styleClass="topbar-label"/>

            <Button text="Guardar partida" onAction="#guardarPartida" styleClass="secondary-button"/>
            <Button text="Pausar" onAction="#pausarPartida" styleClass="secondary-button"/>
            <Button text="Reanudar" onAction="#reanudarPartida" styleClass="secondary-button"/>
            <Button text="Volver al menú" onAction="#volverMenu" styleClass="ghost-button"/>
        </HBox>
    </top>

    <right>
        <VBox spacing="18" styleClass="side-panel">
            <Label text="MiChess" styleClass="side-title"/>
            <Label text="Panel de partida" styleClass="side-label"/>

            <VBox spacing="8" styleClass="info-card">
                <Label text="Cronómetro Blancas" styleClass="side-label"/>
                <Label fx:id="lblTiempoBlancas" text="10:00" styleClass="timer-white"/>
            </VBox>

            <VBox spacing="8" styleClass="info-card">
                <Label text="Cronómetro Negras" styleClass="side-label"/>
                <Label fx:id="lblTiempoNegras" text="10:00" styleClass="timer-black"/>
            </VBox>

            <VBox spacing="8" styleClass="info-card">
                <Label text="Estado de la partida" styleClass="side-label"/>
                <Label fx:id="lblEstado" text="Jugando" styleClass="move-item"/>
            </VBox>

            <Label text="Historial de movimientos" styleClass="side-title-small"/>

            <ScrollPane fitToWidth="true" prefHeight="260"
                        style="-fx-background: transparent; -fx-background-color: transparent;">
                <content>
                    <VBox fx:id="panelMovimientos" spacing="6">
                        <padding>
                            <Insets top="10" right="10" bottom="10" left="10"/>
                        </padding>
                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </right>

</BorderPane>