<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="700.0" prefWidth="380.0" style="-fx-background-color: #1B1B1B;" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tfg.ajedrez.controller.NuevaPartidaController">
   <children>
      <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent;" vbarPolicy="AS_NEEDED">
         <content>
            <VBox alignment="TOP_CENTER" spacing="20.0" style="-fx-background-color: transparent;">
               <padding>
                  <Insets bottom="30.0" left="20.0" right="20.0" top="30.0" />
               </padding>
               <children>
                 
               </children>
            </VBox>
         </content>
      </ScrollPane>
      <Button alignment="TOP_LEFT" contentDisplay="TOP" mnemonicParsing="false" onAction="#onVolver" text="Atrás" StackPane.alignment="TOP_LEFT" />
      <Button mnemonicParsing="false" onAction="#onPartida" text="Partida" />
   </children>
</StackPane>
